# token-monitoring — copy to .env and edit for your deploy.

# ---- Upstream Argo target ---------------------------------------------------
# The Anthropic Messages API-compatible URL the proxy forwards to.
# On arecibo (ANL network) this is Argo directly. Off-network deploys can
# point at a relay (e.g. the JMD argo_relay.py on port 7000).
TM_UPSTREAM_URL=https://apps.inside.anl.gov/argoapi

# Per-request forward timeout in seconds.
TM_UPSTREAM_TIMEOUT_S=120

# ---- Storage ----------------------------------------------------------------
# Path to the usage SQLite file. Auto-created on first run.
TM_DB_PATH=/home/beams/HASKELS/token_monitoring/data/usage.sqlite

# Path to the auth session SQLite file (separate from usage so purges
# never touch auth state).
TM_SESSION_DB_PATH=/home/beams/HASKELS/token_monitoring/data/sessions.sqlite

# ---- PAM sign-in (dashboard only — proxy uses API key) ----------------------
# Master switch. Leave unset in tests / local dev to skip PAM.
TM_PAM_ENABLED=1

# PAM service name. `password-auth` is the standard include on RHEL/Rocky
# that covers the same SSSD → Kerberos path SSHd uses. Override for a
# custom /etc/pam.d/ file (e.g. one that emits an audit tag).
TM_PAM_SERVICE=password-auth

# Sleep-on-failed-auth in seconds (defence-in-depth; libpam's own faildelay
# already runs first).
TM_PAM_FAILURE_DELAY_S=1.0

# ---- Server -----------------------------------------------------------------
TM_HOST=0.0.0.0
TM_PORT=9004
TM_LOG_LEVEL=info

# ---- TLS (shared cert with JMD/Califone/XEOL on arecibo) --------------------
# TM_SSL_KEYFILE=/home/beams/HASKELS/.jmd/tls/key.pem
# TM_SSL_CERTFILE=/home/beams/HASKELS/.jmd/tls/cert.pem
